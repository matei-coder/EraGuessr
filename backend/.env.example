# Copy this file to ".env" and fill in the values. The .env file is gitignored.

# Gemini API key — generate one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Path to the Firebase service account JSON key.
# Firebase Console > Project Settings > Service accounts > Generate new private key.
# Save the downloaded file as backend/serviceAccountKey.json (also gitignored).
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Optional overrides
FIREBASE_PROJECT_ID=hackbase-7fb0e
GEMINI_MODEL=gemini-2.5-flash
